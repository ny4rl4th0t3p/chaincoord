# --- Stage 1: Install dependencies ---
FROM node:20-alpine AS deps
WORKDIR /app
COPY web/app/package.json web/app/yarn.lock ./
RUN yarn install --frozen-lockfile

# --- Stage 2: Build Next.js app ---
FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY web/app/ .

# COORD_BACKEND_URL: server-side proxy target (Docker service name, never reaches the browser).
# NEXT_PUBLIC_API_URL: baked into the client bundle — browser uses this for SSE EventSource.
ARG COORD_BACKEND_URL=http://coordd:8080
ARG NEXT_PUBLIC_API_URL=http://localhost:8080
ENV COORD_BACKEND_URL=$COORD_BACKEND_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
RUN yarn build

# --- Stage 3: Runtime ---
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./
COPY --from=builder /app/public ./public
COPY --from=builder /app/next.config.js ./
EXPOSE 3000
ENV PORT=3000
CMD ["yarn", "start"]