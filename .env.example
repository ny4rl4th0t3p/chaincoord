# chaincoord dev environment — copy to .env and fill in your values.
# Used by docker-compose.yml via variable substitution.

# Required to access the admin panel in the web UI.
# Set to the bech32 address you will sign in with on your coordinator chain
# (e.g. your Cosmos Hub address from Keplr/Leap).
# Comma-separate multiple addresses for shared admin access.
COORD_ADMIN_ADDRESSES=cosmos1youraddresshere